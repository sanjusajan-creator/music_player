{
  "entities": {
    "UserAccount": {
      "title": "UserAccount",
      "description": "Represents a user account within the Vibecraft Music application.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "username", "createdAt"]
    },
    "UserLikedSong": {
      "title": "UserLikedSong",
      "description": "A record of a song liked by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "durationSeconds": { "type": "number" },
        "likedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "likedAt"]
    },
    "Playlist": {
      "title": "Playlist",
      "description": "A user-created collection of songs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "tracks": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "name", "userId", "createdAt"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserAccount",
      "description": "User profile data."
    },
    "/users/{userId}/likedSongs/{songId}": {
      "schema": "UserLikedSong",
      "description": "Songs liked by the user."
    },
    "/users/{userId}/playlists/{playlistId}": {
      "schema": "Playlist",
      "description": "User playlists."
    },
    "/search_cache/{queryId}": {
      "schema": {
        "type": "object",
        "properties": {
          "results": { "type": "array" },
          "timestamp": { "type": "string" }
        }
      },
      "description": "Cache for YouTube search results."
    }
  }
}
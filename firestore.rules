rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Explicitly handle the user data tree
    // The {allPaths=**} wildcard ensures that 'read' (get + list) and 'write' 
    // permissions apply to the user document and ALL nested subcollections (playlists, likedSongs, etc.)
    match /users/{userId}/{allPaths=**} {
      allow get, list, write: if request.auth != null && request.auth.uid == userId;
    }

    // Search cache: Publicly readable for efficiency, writeable by any authenticated user
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny for all other paths
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
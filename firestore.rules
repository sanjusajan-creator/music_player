rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Root user document permission
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Explicit subcollection matching for 'list' and 'read' operations
      // This ensures that collection-wide queries like getDocs() are authorized
      match /playlists/{playlistId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /likedSongs/{songId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Essential rule for search cache to prevent application-wide failure
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
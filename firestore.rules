rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Explicit owner check
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Comprehensive rule for all user-owned data (Profile, Playlists, Liked Songs)
    // Using recursive wildcard {allPaths=**} to ensure subcollections are covered
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    // Search cache for YouTube results - globally readable to reduce API usage
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Default deny for all other paths
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Explicitly handle the user data tree with a robust recursive pattern
    // This allows the user to 'list' collections (like /playlists) and 'get' documents
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Search cache: Publicly readable for efficiency, writeable by any authenticated user
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny for all other paths
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile document: Owner can read/write
    match /users/{userId} {
      allow get, write: if request.auth != null && request.auth.uid == userId;
      
      // Explicitly allow list/get/write for playlists subcollection
      match /playlists/{playlistId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Explicitly allow list/get/write for likedSongs subcollection
      match /likedSongs/{songId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Search cache: Publicly readable, writeable by any authenticated user
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny all other access by default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
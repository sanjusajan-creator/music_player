rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User Data: Explicit paths for reliable listing and reading
    // This allows the owner to list their collections (playlists, likedSongs) and read/write all documents within them.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Explicitly allow subcollections for the list operation
      match /playlists/{playlistId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /likedSongs/{songId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Recursive catch-all for any other nested data
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Search cache: Essential for core search functionality
    // Allows public reading for performance and authenticated writing for updating results
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
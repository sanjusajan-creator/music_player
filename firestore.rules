rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Explicit rule for the user document and all nested collections
    // This uses a robust recursive wildcard to ensure 'list' operations on 
    // subcollections like /playlists and /likedSongs are authorized for the owner.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Search cache: Globally readable for performance, writeable by any authenticated user.
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny all other access by default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
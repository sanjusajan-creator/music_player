rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Explicitly handle the user data tree
    // This structure ensures that both individual document access and 
    // collection-wide 'list' operations (getDocs) are authorized for the owner.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Explicit subcollection matches are the most robust way to authorize LIST operations
      match /playlists/{playlistId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /likedSongs/{songId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Recursive catch-all for any other nested data
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Search cache: Publicly readable for efficiency, writeable by any authenticated user
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny for all other paths
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
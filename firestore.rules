rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User-owned data tree: Allows full access to the user document and all subcollections
    // (playlists, likedSongs, etc.) only if the authenticated UID matches the path.
    // The recursive wildcard {allPaths=**} ensures that 'list' operations on collections
    // like /users/{userId}/playlists are permitted.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Search cache: Globally readable to optimize YouTube API quota usage.
    // Writeable by any authenticated user.
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny for anything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
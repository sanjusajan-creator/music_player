rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Robust recursive rule for all user-owned data
    // This covers /users/{userId}, /users/{userId}/playlists, /users/{userId}/likedSongs, etc.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Search cache for YouTube results - globally readable to reduce API usage
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny for all other paths
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
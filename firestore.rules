rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Explicit owner check
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Rules for user-specific data (Playlists, Liked Songs, Profile)
    match /users/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);
      
      // Explicit rules for subcollections
      match /playlists/{playlistId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
      
      match /likedSongs/{songId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    // Search cache for YouTube results - globally readable to reduce API usage
    match /search_cache/{queryId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
    }

    // Default deny for all other paths
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
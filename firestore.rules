rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Applied exactly as requested: recursive wildcard for user data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Necessary for the search functionality to work without permission errors
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

  }
}
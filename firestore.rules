rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // RECURSIVE USER DATA ACCESS
    // This structure explicitly authorizes 'list' operations on subcollections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // SEARCH CACHE (Required for music search functionality)
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
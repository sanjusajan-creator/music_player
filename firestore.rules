rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of the document or path
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Comprehensive rules for user-specific data
    match /users/{userId} {
      // Explicitly allow all read/write operations for the owner
      allow get, list, create, update, delete: if isOwner(userId);
      
      // Explicitly allow recursive access to subcollections like playlists and likedSongs
      match /{allPaths=**} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    // Search cache for YouTube results - globally readable to reduce API usage
    match /search_cache/{queryId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
    }

    // Default deny for all other paths
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
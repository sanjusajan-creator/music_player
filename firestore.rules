rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User data rules: Explicitly match subcollections to ensure LIST operations work
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Explicit playlists subcollection rule for getDocs/onSnapshot listing
      match /playlists/{playlistId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Explicit likedSongs subcollection rule for getDocs/onSnapshot listing
      match /likedSongs/{songId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Search cache: Essential for core app functionality
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USER DATA: Recursive wildcard ensures all subcollections are authorized for the owner
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // USER ROOT: Explicitly allow the root user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // SEARCH CACHE: Required for YouTube engine functionality
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
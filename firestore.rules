rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User data: Recursive wildcard match as requested
    // This allows the authenticated owner to read/write their own document and all subcollections (playlists, likedSongs, etc.)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Search cache: Essential for core search functionality
    // Allows public reading for performance and authenticated writing for updating results
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
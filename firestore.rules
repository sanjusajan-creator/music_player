rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User data tree: Explicitly recursive to allow get/list/write on all subcollections
    // This resolves the 'list' permission error on /users/{uid}/playlists
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Search cache: Publicly readable for efficiency, writeable by any authenticated user
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
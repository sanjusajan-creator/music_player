rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Recursive wildcard match for all data belonging to a specific user.
    // This allows get, list, create, update, and delete for the user document
    // and all nested subcollections (playlists, likedSongs, etc.)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Search cache: Publicly readable for efficiency, writeable by any authenticated user.
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny for all other paths to ensure security.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Explicitly allow users to read and write their own data tree
    // This handles both the user document and all nested subcollections (playlists, likedSongs, etc.)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Explicitly allow list operations for personal subcollections to satisfy broad collection queries
    match /users/{userId}/playlists/{playlistId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /users/{userId}/likedSongs/{songId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Search cache: Globally readable for performance, writeable by any authenticated user.
    match /search_cache/{queryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny all other access by default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
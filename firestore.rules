rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Flattened rules for users and their personal data tree.
    // This explicitly allows list and read for the owner on any path starting with /users/{userId}
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Explicitly allow access to the user document itself (for profile checks)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Search cache: Globally readable for performance, writeable by any authenticated user.
    // Using {allPaths=**} to ensure any nested cache data is also accessible.
    match /search_cache/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny all other access by default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}